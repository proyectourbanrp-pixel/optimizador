{
  "name": "pagina",
  "version": "1.1.0",
  "description": "VYRONIX Optimizer - Sistema de monitoreo y optimización",
  "main": "main.js",
  "author": "Juan Camilo",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --remote-debugging-port=9222",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "optimizer",
    "system-monitor",
    "windows",
    "electron"
  ],
  "dependencies": {
    "electron": "^41.2.2"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.vyronix.optimizer",
    "productName": "VYRONIX Optimizer",
    "files": [
      "main.js",
      "preload.js",
      "main-ipc.js",
      "renderer-ui.js",
      "app.js",
      "index.html",
      "styles.css",
      "utils/**",
      "scripts/**",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}